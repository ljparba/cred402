# ─────────────────────────────────────────────────────────────────────────────
# Cred402 environment variables
#
# Copy to `.env.local` for Next.js (server) usage:   cp .env.example .env.local
# Nothing here is required to BUILD or to run the app in "unconfigured mode"
# (offline fixtures). Hedera + x402 live behaviour needs the marked variables.
# NEVER commit real secrets. `.env*` is gitignored (except this example).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Optional. If UNSET, the app uses embedded PGlite at PGLITE_DATA_DIR (no server
# needed) — the default local path on a machine without Postgres.
# Neon (dev):      postgres://USER:PASS@ep-xxx.neon.tech/db?sslmode=require
# Render (prod):   postgres://USER:PASS@dpg-xxx.render.com/db?sslmode=require
# Required on Render: YES.  Required for local dev: NO (PGlite fallback).
DATABASE_URL=

# Directory for the embedded PGlite database when DATABASE_URL is unset.
# Server-only. Default: ./.pglite
PGLITE_DATA_DIR=./.pglite

# The app reports THREE INDEPENDENT capability flags at GET /api/health
# (config.hcsWriteConfigured / x402SettlementConfigured / demoWalletConfigured).
# The variable groups below map one-to-one onto them:
#
#   hcsWriteConfigured       ← HEDERA_OPERATOR_ID + HEDERA_OPERATOR_PRIVATE_KEY
#                              (+ HEDERA_HCS_TOPIC_ID to anchor to a topic)
#   x402SettlementConfigured ← X402_PAYMENT_RECIPIENT (+ X402_* defaults).
#                              Does NOT need the HCS operator private key: the
#                              buyer signs the transfer, the facilitator sponsors.
#   demoWalletConfigured     ← X402_DEMO_PAYER_ID + _PRIVATE_KEY, on top of
#                              x402SettlementConfigured.

# ── Hedera / HCS WRITE (server-only — NEVER expose the private key) ───────────
# Needed ONLY to submit HCS messages (issuance/revocation anchoring, tamper
# demo). The report settlement flow does NOT require the operator private key.
# Obtain the operator account from https://portal.hedera.com (testnet).
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_PRIVATE_KEY=
# Created by `npm run hedera:create-topic` (script writes the id here). Server-only.
HEDERA_HCS_TOPIC_ID=
# Mirror Node REST base (no trailing slash). Default shown. Used for the
# independent settlement confirmation — a READ, needs no keys.
MIRROR_NODE_BASE_URL=https://testnet.mirrornode.hedera.com

# ── x402 SETTLEMENT (server-only unless prefixed NEXT_PUBLIC_) ────────────────
# Enough to run the report 402 → settlement flow. Only X402_PAYMENT_RECIPIENT is
# required; the rest have working defaults. NO operator private key needed here.
X402_NETWORK=hedera:testnet
# The account that RECEIVES payment for a report. Usually the operator id.
X402_PAYMENT_RECIPIENT=
# Official x402 facilitator (co-signs as fee payer, submits). Default shown.
X402_FACILITATOR_URL=https://x402.org/facilitator
# Price of one full report, in tinybars (1 HBAR = 100_000_000). 0.1 HBAR shown.
X402_PRICE=10000000
# HBAR-native asset id in the Hedera exact scheme.
X402_ASSET=0.0.0

# ── Demo WALLET (built-in server-side payer — server-only) ───────────────────
# Second funded testnet account the browser demo uses to settle the 402 for the
# user. Requires the x402 settlement values above as well. Derived + funded by
# `npm run hedera:create-demo-wallet`.
X402_DEMO_PAYER_ID=
X402_DEMO_PAYER_PRIVATE_KEY=

# ── Create Tamper Demo (public HCS-writing endpoint — protect it) ────────────
# Master switch for POST /api/demo/register. Keep FALSE unless you want the
# public tamper-demo registration live (it anchors to HCS in configured mode).
TAMPER_DEMO_ENABLED=false
# Max demo registrations per IP per window, and the window length (seconds).
TAMPER_DEMO_RATE_LIMIT_MAX=3
TAMPER_DEMO_RATE_LIMIT_WINDOW_SECONDS=3600

# ── Public (safe to expose to the browser) ───────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_HASHSCAN_BASE_URL=https://hashscan.io/testnet
# Your public repository URL (used by the nav/footer "GitHub" links).
NEXT_PUBLIC_GITHUB_URL=https://github.com/

# ── Public-endpoint rate limits (DB-backed, per hashed IP) ───────────────────
# Best-effort abuse brakes on the public endpoints (the client IP is SHA-256
# hashed before storage — the raw IP is never persisted). These do NOT replace
# the per-request payment lock. /api/verify and /api/pay use SEPARATE buckets.
VERIFY_RATE_LIMIT_MAX=20
VERIFY_RATE_LIMIT_WINDOW_SECONDS=3600
# Stricter, because /api/pay spends real testnet HBAR from the demo wallet.
PAY_RATE_LIMIT_MAX=5
PAY_RATE_LIMIT_WINDOW_SECONDS=3600

# ── Uploads ──────────────────────────────────────────────────────────────────
# Max per-FILE size in bytes. Authoritative check, applied after parsing. 5 MB.
MAX_UPLOAD_SIZE=5242880
# Whole-REQUEST body ceiling, checked against Content-Length BEFORE parsing so a
# clearly-oversized upload is rejected early (413). Must be ABOVE MAX_UPLOAD_SIZE
# to leave room for multipart overhead. Default: MAX_UPLOAD_SIZE + 1 MB.
# Complements (does not replace) any deployment/proxy body limit.
MAX_UPLOAD_REQUEST_SIZE=6291456
